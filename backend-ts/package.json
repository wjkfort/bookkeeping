{
  "name": "bookkeeping-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 execute bookkeeping-db --local --file=./migrations/schema.sql",
    "db:migrate:remote": "wrangler d1 execute bookkeeping-db --remote --file=./migrations/schema.sql"
  },
  "dependencies": {
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240208.0",
    "wrangler": "^3.28.0",
    "typescript": "^5.3.3"
  }
}
