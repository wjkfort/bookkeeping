# Cloudflare Pages Configuration

# Build configuration
[build]
  command = "npm run build"
  publish = "dist"

# Environment variables for production
[build.environment]
  NODE_VERSION = "18"

# Redirects and headers
[[redirects]]
  from = "/api/*"
  to = "https://bookkeeping-backend.YOUR_SUBDOMAIN.workers.dev/api/:splat"
  status = 200
  force = true

# SPA fallback - redirect all routes to index.html
[[redirects]]
  from = "/*"
  to = "/index.html"
  status = 200
